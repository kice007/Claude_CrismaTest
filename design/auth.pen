{
  "version": "1.0",
  "variables": {
    "brand-primary": "#1B4FD8",
    "brand-secondary": "#3B6FE8",
    "brand-navy": "#0F2A6B",
    "brand-light": "#EEF2FF",
    "brand-accent": "#6366F1",
    "font-sans": "Inter",
    "font-mono": "JetBrains Mono"
  },
  "imports": [
    { "file": "landing-pages.pen", "nodeId": "nav-shell", "as": "NavShell" }
  ],
  "nodes": [
    {
      "id": "sign-up",
      "type": "frame",
      "label": "sign-up — /sign-up desktop",
      "width": 1440,
      "height": 900,
      "fill": { "type": "solid", "color": "var(brand-light)" },
      "layout": "vertical",
      "align": "center",
      "justify": "center",
      "children": [
        {
          "id": "sign-up-card",
          "type": "frame",
          "label": "Auth card",
          "width": 480,
          "layout": "vertical",
          "gap": 20,
          "padding": { "x": 40, "y": 40 },
          "fill": { "type": "solid", "color": "#FFFFFF" },
          "cornerRadius": 12,
          "shadow": { "type": "md" },
          "children": [
            {
              "id": "sign-up-logo",
              "type": "rect",
              "label": "← LogoMark from src/components/nav/LogoMark.tsx",
              "width": 120,
              "height": 40,
              "fill": { "type": "solid", "color": "var(brand-primary)" },
              "cornerRadius": 4,
              "align": "center"
            },
            {
              "id": "sign-up-heading",
              "type": "text",
              "label": "Create your account",
              "fontSize": 24,
              "fontWeight": "bold",
              "fontFamily": "var(font-sans)",
              "color": "var(brand-navy)",
              "align": "center"
            },
            {
              "id": "sign-up-role-selector",
              "type": "frame",
              "label": "Role selector toggle",
              "layout": "horizontal",
              "gap": 0,
              "width": 400,
              "height": 44,
              "cornerRadius": 8,
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "role-candidate-btn",
                  "type": "frame",
                  "label": "Candidate (selected)",
                  "flex": 1,
                  "height": 44,
                  "fill": { "type": "solid", "color": "var(brand-primary)" },
                  "cornerRadius": 8,
                  "layout": "horizontal",
                  "align": "center",
                  "justify": "center",
                  "children": [
                    {
                      "id": "role-candidate-text",
                      "type": "text",
                      "label": "Candidate",
                      "fontSize": 14,
                      "fontWeight": "semibold",
                      "fontFamily": "var(font-sans)",
                      "color": "#FFFFFF"
                    }
                  ]
                },
                {
                  "id": "role-company-btn",
                  "type": "frame",
                  "label": "Company (outline / unselected)",
                  "flex": 1,
                  "height": 44,
                  "fill": { "type": "none" },
                  "border": { "color": "var(brand-primary)", "width": 1 },
                  "cornerRadius": 8,
                  "layout": "horizontal",
                  "align": "center",
                  "justify": "center",
                  "children": [
                    {
                      "id": "role-company-text",
                      "type": "text",
                      "label": "Company",
                      "fontSize": 14,
                      "fontWeight": "semibold",
                      "fontFamily": "var(font-sans)",
                      "color": "var(brand-primary)"
                    }
                  ]
                }
              ]
            },
            {
              "id": "sign-up-full-name",
              "type": "frame",
              "label": "Full Name field",
              "layout": "vertical",
              "gap": 6,
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "sign-up-full-name-label",
                  "type": "text",
                  "label": "Full Name",
                  "fontSize": 13,
                  "fontWeight": "medium",
                  "fontFamily": "var(font-sans)",
                  "color": "#374151"
                },
                {
                  "id": "sign-up-full-name-input",
                  "type": "frame",
                  "label": "Text input",
                  "width": 400,
                  "height": 44,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "border": { "color": "#D1D5DB", "width": 1 },
                  "cornerRadius": 6,
                  "layout": "horizontal",
                  "align": "center",
                  "padding": { "x": 12, "y": 0 },
                  "children": [
                    {
                      "id": "sign-up-full-name-placeholder",
                      "type": "text",
                      "label": "Jane Doe",
                      "fontSize": 14,
                      "fontFamily": "var(font-sans)",
                      "color": "#9CA3AF"
                    }
                  ]
                }
              ]
            },
            {
              "id": "sign-up-email",
              "type": "frame",
              "label": "Email field",
              "layout": "vertical",
              "gap": 6,
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "sign-up-email-label",
                  "type": "text",
                  "label": "Email",
                  "fontSize": 13,
                  "fontWeight": "medium",
                  "fontFamily": "var(font-sans)",
                  "color": "#374151"
                },
                {
                  "id": "sign-up-email-input",
                  "type": "frame",
                  "label": "Text input",
                  "width": 400,
                  "height": 44,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "border": { "color": "#D1D5DB", "width": 1 },
                  "cornerRadius": 6,
                  "layout": "horizontal",
                  "align": "center",
                  "padding": { "x": 12, "y": 0 },
                  "children": [
                    {
                      "id": "sign-up-email-placeholder",
                      "type": "text",
                      "label": "jane@example.com",
                      "fontSize": 14,
                      "fontFamily": "var(font-sans)",
                      "color": "#9CA3AF"
                    }
                  ]
                }
              ]
            },
            {
              "id": "sign-up-password",
              "type": "frame",
              "label": "Password field",
              "layout": "vertical",
              "gap": 6,
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "sign-up-password-label",
                  "type": "text",
                  "label": "Password",
                  "fontSize": 13,
                  "fontWeight": "medium",
                  "fontFamily": "var(font-sans)",
                  "color": "#374151"
                },
                {
                  "id": "sign-up-password-input",
                  "type": "frame",
                  "label": "Password input with show/hide toggle",
                  "width": 400,
                  "height": 44,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "border": { "color": "#D1D5DB", "width": 1 },
                  "cornerRadius": 6,
                  "layout": "horizontal",
                  "align": "center",
                  "padding": { "x": 12, "y": 0 },
                  "gap": 0,
                  "children": [
                    {
                      "id": "sign-up-password-value",
                      "type": "text",
                      "label": "••••••••",
                      "fontSize": 14,
                      "fontFamily": "var(font-sans)",
                      "color": "#374151",
                      "flex": 1
                    },
                    {
                      "id": "sign-up-password-eye",
                      "type": "rect",
                      "label": "show/hide password — eye icon toggle",
                      "width": 20,
                      "height": 20,
                      "fill": { "type": "solid", "color": "#9CA3AF" },
                      "cornerRadius": 2,
                      "annotation": "Eye icon — toggles input type between password and text (Auth-01)"
                    }
                  ]
                }
              ]
            },
            {
              "id": "sign-up-cta",
              "type": "frame",
              "label": "Create Account CTA",
              "width": 400,
              "height": 48,
              "fill": { "type": "solid", "color": "var(brand-primary)" },
              "cornerRadius": 8,
              "layout": "horizontal",
              "align": "center",
              "justify": "center",
              "children": [
                {
                  "id": "sign-up-cta-text",
                  "type": "text",
                  "label": "Create Account",
                  "fontSize": 15,
                  "fontWeight": "semibold",
                  "fontFamily": "var(font-sans)",
                  "color": "#FFFFFF"
                }
              ]
            },
            {
              "id": "sign-up-divider",
              "type": "frame",
              "label": "Divider row",
              "layout": "horizontal",
              "gap": 12,
              "align": "center",
              "fill": { "type": "none" },
              "width": 400,
              "children": [
                {
                  "id": "sign-up-divider-line-left",
                  "type": "rect",
                  "label": "",
                  "flex": 1,
                  "height": 1,
                  "fill": { "type": "solid", "color": "#E5E7EB" }
                },
                {
                  "id": "sign-up-divider-text",
                  "type": "text",
                  "label": "or continue with",
                  "fontSize": 12,
                  "fontFamily": "var(font-sans)",
                  "color": "#9CA3AF"
                },
                {
                  "id": "sign-up-divider-line-right",
                  "type": "rect",
                  "label": "",
                  "flex": 1,
                  "height": 1,
                  "fill": { "type": "solid", "color": "#E5E7EB" }
                }
              ]
            },
            {
              "id": "sign-up-oauth-btn",
              "type": "frame",
              "label": "Google OAuth button",
              "width": 400,
              "height": 48,
              "fill": { "type": "solid", "color": "#FFFFFF" },
              "border": { "color": "#D1D5DB", "width": 1 },
              "cornerRadius": 8,
              "layout": "horizontal",
              "align": "center",
              "justify": "center",
              "gap": 10,
              "children": [
                {
                  "id": "sign-up-google-logo",
                  "type": "rect",
                  "label": "Google logo placeholder",
                  "width": 20,
                  "height": 20,
                  "fill": { "type": "solid", "color": "#EA4335" },
                  "cornerRadius": 10
                },
                {
                  "id": "sign-up-google-text",
                  "type": "text",
                  "label": "Sign in with Google",
                  "fontSize": 14,
                  "fontWeight": "medium",
                  "fontFamily": "var(font-sans)",
                  "color": "#374151"
                }
              ]
            },
            {
              "id": "sign-up-footer-link",
              "type": "text",
              "label": "Already have an account? Login",
              "fontSize": 13,
              "fontFamily": "var(font-sans)",
              "color": "#6B7280",
              "align": "center",
              "annotation": "Login link → /login"
            }
          ]
        },
        {
          "id": "sign-up-no-navshell-note",
          "type": "note",
          "label": "← NavShell omitted on auth pages — full-screen centered card layout per AUTH-01",
          "x": 20,
          "y": 20
        },
        {
          "id": "sign-up-oauth-note",
          "type": "note",
          "label": "→ Google OAuth shows 'Coming soon' toast on click (visual only, AUTH-01)",
          "x": 20,
          "y": 60
        }
      ]
    },
    {
