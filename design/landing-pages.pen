                  "gap": 16,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "shadow": { "type": "sm" },
                  "children": [
                    { "id": "fc3-icon", "type": "rect", "width": 40, "height": 40, "cornerRadius": 8, "fill": { "type": "solid", "color": "var(brand-light)" }, "label": "[Chart icon]" },
                    { "id": "fc3-title", "type": "text", "content": "Verifiable CrismaScore", "fontSize": 16, "fontFamily": "var(font-sans)", "fontWeight": 600, "color": "#111827" },
                    { "id": "fc3-body", "type": "text", "content": "Each candidate gets a portable, cryptographically-signed score they can share on LinkedIn and resumes", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#6B7280", "lineHeight": 1.5 }
                  ]
                }
              ]
