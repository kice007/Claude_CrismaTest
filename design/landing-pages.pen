{
  "version": "1.0",
  "variables": {
    "brand-primary": "#1B4FD8",
    "brand-secondary": "#3B6FE8",
    "brand-navy": "#0F2A6B",
    "brand-light": "#EEF2FF",
    "brand-accent": "#6366F1",
    "font-sans": "Inter",
    "font-mono": "JetBrains Mono"
  },
  "nodes": [
    {
      "id": "nav-shell",
      "type": "frame",
      "label": "NavShell",
      "reusable": true,
      "width": 1440,
      "height": 72,
      "layout": "horizontal",
      "align": "center",
      "padding": { "x": 32, "y": 0 },
      "gap": 0,
      "fill": { "type": "solid", "color": "var(brand-light)", "opacity": 0.95 },
      "backdropBlur": 12,
      "shadow": { "type": "sm", "annotation": "shadow-sm applied on scroll via js class toggle" },
      "children": [
        {
          "id": "nav-shell-logo",
          "type": "rect",
          "label": "← LogoMark from src/components/nav/LogoMark.tsx",
          "width": 120,
          "height": 40,
          "fill": { "type": "solid", "color": "var(brand-primary)" },
          "cornerRadius": 4
        },
        {
          "id": "nav-shell-spacer-left",
          "type": "rect",
          "label": "flex-1 spacer",
          "fill": { "type": "none" },
          "flex": 1
        },
        {
          "id": "nav-shell-links",
          "type": "frame",
          "label": "Nav links",
          "layout": "horizontal",
          "gap": 32,
          "fill": { "type": "none" },
          "children": [
            { "id": "nav-link-home", "type": "text", "label": "Home", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" },
            { "id": "nav-link-candidates", "type": "text", "label": "For Candidates", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" },
            { "id": "nav-link-companies", "type": "text", "label": "For Companies", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" },
            { "id": "nav-link-pricing", "type": "text", "label": "Pricing", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" },
            { "id": "nav-link-contact", "type": "text", "label": "Contact", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" }
          ]
        },
        {
          "id": "nav-shell-spacer-right",
          "type": "rect",
          "label": "flex-1 spacer",
          "fill": { "type": "none" },
          "flex": 1
        },
        {
          "id": "nav-shell-right",
          "type": "frame",
          "label": "Right group",
          "layout": "horizontal",
          "gap": 8,
          "align": "center",
          "fill": { "type": "none" },
          "children": [
            {
              "id": "nav-lang-en",
              "type": "rect",
              "label": "EN",
              "width": 36,
              "height": 28,
              "cornerRadius": 4,
              "fill": { "type": "solid", "color": "var(brand-primary)", "opacity": 0.1 },
              "text": "EN",
              "fontSize": 12
            },
            {
              "id": "nav-lang-fr",
              "type": "rect",
              "label": "FR",
              "width": 36,
              "height": 28,
              "cornerRadius": 4,
              "fill": { "type": "none" },
              "stroke": { "color": "#D1D5DB", "width": 1 },
              "text": "FR",
              "fontSize": 12
            },
            {
              "id": "nav-login-btn",
              "type": "rect",
              "label": "Login",
              "width": 72,
              "height": 36,
              "cornerRadius": 6,
              "fill": { "type": "none" },
              "stroke": { "color": "var(brand-primary)", "width": 1 },
              "text": "Login",
              "fontSize": 14,
              "fontFamily": "var(font-sans)",
              "textColor": "var(brand-primary)"
            },
            {
              "id": "nav-signup-btn",
              "type": "rect",
              "label": "Sign Up",
              "width": 88,
              "height": 36,
              "cornerRadius": 6,
              "fill": { "type": "solid", "color": "var(brand-primary)" },
              "text": "Sign Up",
              "fontSize": 14,
              "fontFamily": "var(font-sans)",
              "textColor": "#FFFFFF",
              "fontWeight": 600
            }
          ]
        }
      ]
    },
    {
      "id": "nav-shell-annotation",
      "type": "note",
      "content": "← NavShell from src/components/nav/NavShell.tsx — white/95 backdrop-blur, shadow on scroll. Reusable: true — referenced by auth.pen and test-flow.pen via cross-file import.",
      "x": 0,
      "y": -40
    },
    {
      "id": "home",
      "type": "frame",
      "label": "home",
      "width": 1440,
      "layout": "vertical",
      "gap": 0,
      "fill": { "type": "solid", "color": "var(brand-light)" },
      "children": [
        {
          "id": "home-nav",
          "type": "ref",
          "label": "NavShell ref",
          "ref": "nav-shell"
        },
        {
          "id": "home-hero",
          "type": "frame",
          "label": "Hero section",
          "width": 1440,
          "height": 640,
          "layout": "vertical",
          "align": "center",
          "justify": "center",
          "gap": 24,
          "fill": {
            "type": "gradient",
            "gradient": "linear",
            "angle": 135,
            "stops": [
              { "offset": 0, "color": "var(brand-navy)" },
              { "offset": 1, "color": "var(brand-primary)", "opacity": 0.85 }
            ]
          },
          "children": [
            {
              "id": "home-hero-eyebrow",
              "type": "text",
              "label": "Eyebrow",
              "content": "Trusted by 200+ companies across North America",
              "fontSize": 14,
              "fontFamily": "var(font-sans)",
              "color": "var(brand-accent)",
              "fontWeight": 500,
              "letterSpacing": 0.5,
              "textTransform": "uppercase"
            },
            {
              "id": "home-hero-headline",
              "type": "text",
              "label": "Hero headline",
              "content": "Find top talent with confidence",
              "fontSize": 60,
              "fontFamily": "var(font-sans)",
              "fontWeight": 800,
              "color": "#FFFFFF",
              "lineHeight": 1.1,
              "maxWidth": 760,
              "textAlign": "center"
            },
            {
              "id": "home-hero-subheadline",
              "type": "text",
              "label": "Hero sub-headline",
              "content": "CrismaTest verifies real skills with proctored assessments and a verifiable CrismaScore — so you hire with certainty, not guesswork.",
              "fontSize": 20,
              "fontFamily": "var(font-sans)",
              "fontWeight": 400,
              "color": "#E0E7FF",
              "lineHeight": 1.5,
              "maxWidth": 580,
              "textAlign": "center"
            },
            {
              "id": "home-hero-ctas",
              "type": "frame",
              "label": "CTA buttons",
              "layout": "horizontal",
              "gap": 16,
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "home-cta-primary",
                  "type": "rect",
                  "label": "Get Started",
                  "width": 160,
                  "height": 48,
                  "cornerRadius": 8,
                  "fill": { "type": "solid", "color": "var(brand-primary)" },
                  "text": "Get Started",
                  "fontSize": 16,
                  "fontFamily": "var(font-sans)",
                  "fontWeight": 600,
                  "textColor": "#FFFFFF"
                },
                {
                  "id": "home-cta-secondary",
                  "type": "rect",
                  "label": "Watch Demo",
                  "width": 160,
                  "height": 48,
                  "cornerRadius": 8,
                  "fill": { "type": "none" },
                  "stroke": { "color": "#FFFFFF", "width": 2 },
                  "text": "Watch Demo",
                  "fontSize": 16,
                  "fontFamily": "var(font-sans)",
                  "fontWeight": 600,
                  "textColor": "#FFFFFF"
                }
              ]
            },
            {
              "id": "home-hero-dashboard-card",
              "type": "frame",
              "label": "[Floating dashboard card — frosted edges]",
              "width": 680,
              "height": 320,
              "cornerRadius": 16,
              "fill": { "type": "solid", "color": "#FFFFFF", "opacity": 0.12 },
              "backdropBlur": 16,
              "stroke": { "color": "#FFFFFF", "opacity": 0.2, "width": 1 },
              "shadow": { "type": "lg" },
              "annotation": "Simplified candidate table mockup — frosted/blurred edges. See Phase 3 CONTEXT for seeded data (Marie Dupont, Score 78, Product Manager)",
              "children": [
                {
                  "id": "hero-card-header",
                  "type": "text",
                  "label": "Card label",
                  "content": "Recent Candidates",
                  "fontSize": 13,
                  "fontFamily": "var(font-sans)",
                  "fontWeight": 600,
                  "color": "#FFFFFF"
                },
                {
                  "id": "hero-card-row-1",
                  "type": "frame",
                  "label": "Candidate row 1",
                  "layout": "horizontal",
                  "gap": 16,
                  "fill": { "type": "solid", "color": "#FFFFFF", "opacity": 0.08 },
                  "padding": { "x": 16, "y": 10 },
                  "children": [
                    { "id": "r1-name", "type": "text", "content": "Marie Dupont", "fontSize": 13, "color": "#FFFFFF" },
                    { "id": "r1-role", "type": "text", "content": "Product Manager", "fontSize": 12, "color": "#C7D2FE" },
                    { "id": "r1-score", "type": "rect", "label": "Score badge 78", "width": 40, "height": 22, "cornerRadius": 11, "fill": { "type": "solid", "color": "var(brand-accent)" }, "text": "78", "fontSize": 12, "textColor": "#FFFFFF" }
                  ]
                },
                {
                  "id": "hero-card-row-2",
                  "type": "frame",
                  "label": "Candidate row 2",
                  "layout": "horizontal",
                  "gap": 16,
                  "fill": { "type": "none" },
                  "padding": { "x": 16, "y": 10 },
                  "children": [
                    { "id": "r2-name", "type": "text", "content": "Thomas Laurent", "fontSize": 13, "color": "#FFFFFF" },
                    { "id": "r2-role", "type": "text", "content": "Software Engineer", "fontSize": 12, "color": "#C7D2FE" },
                    { "id": "r2-score", "type": "rect", "label": "Score badge 91", "width": 40, "height": 22, "cornerRadius": 11, "fill": { "type": "solid", "color": "#10B981" }, "text": "91", "fontSize": 12, "textColor": "#FFFFFF" }
                  ]
                },
                {
                  "id": "hero-card-row-3",
                  "type": "frame",
                  "label": "Candidate row 3",
                  "layout": "horizontal",
                  "gap": 16,
                  "fill": { "type": "solid", "color": "#FFFFFF", "opacity": 0.08 },
                  "padding": { "x": 16, "y": 10 },
                  "children": [
                    { "id": "r3-name", "type": "text", "content": "Sophie Chen", "fontSize": 13, "color": "#FFFFFF" },
                    { "id": "r3-role", "type": "text", "content": "Data Analyst", "fontSize": 12, "color": "#C7D2FE" },
                    { "id": "r3-score", "type": "rect", "label": "Score badge 65", "width": 40, "height": 22, "cornerRadius": 11, "fill": { "type": "solid", "color": "#F59E0B" }, "text": "65", "fontSize": 12, "textColor": "#FFFFFF" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "home-trust-bar",
          "type": "frame",
          "label": "Trust bar",
          "width": 1440,
          "height": 80,
          "layout": "horizontal",
          "align": "center",
          "justify": "center",
          "gap": 48,
          "fill": { "type": "solid", "color": "#FFFFFF" },
          "children": [
            { "id": "logo-1", "type": "rect", "label": "Company logo 1", "width": 120, "height": 32, "fill": { "type": "solid", "color": "#E5E7EB" }, "cornerRadius": 4 },
            { "id": "logo-2", "type": "rect", "label": "Company logo 2", "width": 100, "height": 32, "fill": { "type": "solid", "color": "#E5E7EB" }, "cornerRadius": 4 },
            { "id": "logo-3", "type": "rect", "label": "Company logo 3", "width": 130, "height": 32, "fill": { "type": "solid", "color": "#E5E7EB" }, "cornerRadius": 4 },
            { "id": "logo-4", "type": "rect", "label": "Company logo 4", "width": 90, "height": 32, "fill": { "type": "solid", "color": "#E5E7EB" }, "cornerRadius": 4 },
            { "id": "logo-5", "type": "rect", "label": "Company logo 5", "width": 110, "height": 32, "fill": { "type": "solid", "color": "#E5E7EB" }, "cornerRadius": 4 }
          ],
          "annotation": "[Trust bar — company logos marquee]"
        },
        {
          "id": "home-what-is",
          "type": "frame",
          "label": "What-is section",
          "width": 1440,
          "height": 480,
          "layout": "horizontal",
          "align": "center",
          "padding": { "x": 120, "y": 80 },
          "gap": 80,
          "fill": { "type": "solid", "color": "var(brand-light)" },
          "children": [
            {
              "id": "what-is-text",
              "type": "frame",
              "label": "Text column",
              "flex": 1,
              "layout": "vertical",
              "gap": 24,
              "fill": { "type": "none" },
              "children": [
                { "id": "what-is-headline", "type": "text", "content": "Skills verification that both sides trust", "fontSize": 36, "fontFamily": "var(font-sans)", "fontWeight": 700, "color": "#111827", "lineHeight": 1.2 },
                { "id": "what-is-body", "type": "text", "content": "CrismaTest runs proctored, AI-monitored assessments covering six question formats. Candidates get a portable CrismaScore they can share. Companies get verifiable, comparable data to make faster, fairer decisions.", "fontSize": 16, "fontFamily": "var(font-sans)", "color": "#6B7280", "lineHeight": 1.6 },
                { "id": "what-is-cta", "type": "rect", "label": "Learn More CTA", "width": 140, "height": 44, "cornerRadius": 6, "fill": { "type": "solid", "color": "var(brand-primary)" }, "text": "Learn More", "fontSize": 14, "textColor": "#FFFFFF" }
              ]
            },
            {
              "id": "what-is-visual",
              "type": "rect",
              "label": "[What-is visual — product screenshot placeholder]",
              "flex": 1,
              "height": 320,
              "cornerRadius": 12,
              "fill": { "type": "solid", "color": "#E0E7FF" },
              "stroke": { "color": "var(brand-secondary)", "width": 2 }
            }
          ]
        },
        {
          "id": "home-process",
          "type": "frame",
          "label": "3-step process",
          "width": 1440,
          "height": 360,
          "layout": "vertical",
          "align": "center",
          "padding": { "x": 120, "y": 64 },
          "gap": 48,
          "fill": { "type": "solid", "color": "#FFFFFF" },
          "children": [
            { "id": "process-headline", "type": "text", "content": "How it works", "fontSize": 32, "fontFamily": "var(font-sans)", "fontWeight": 700, "color": "#111827", "textAlign": "center" },
            {
              "id": "process-steps",
              "type": "frame",
              "label": "Steps row",
              "layout": "horizontal",
              "gap": 40,
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "step-1",
                  "type": "frame",
                  "label": "Step 1",
                  "flex": 1,
                  "layout": "vertical",
                  "align": "center",
                  "gap": 16,
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "step-1-circle", "type": "rect", "label": "1", "width": 48, "height": 48, "cornerRadius": 24, "fill": { "type": "solid", "color": "var(brand-accent)" }, "text": "1", "fontSize": 18, "fontWeight": 700, "textColor": "#FFFFFF" },
                    { "id": "step-1-label", "type": "text", "content": "Invite Candidates", "fontSize": 16, "fontFamily": "var(font-sans)", "fontWeight": 600, "color": "#111827", "textAlign": "center" },
                    { "id": "step-1-desc", "type": "text", "content": "Send a test link directly from your dashboard or integrate via API", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#6B7280", "textAlign": "center" }
                  ]
                },
                {
                  "id": "step-2",
                  "type": "frame",
                  "label": "Step 2",
                  "flex": 1,
                  "layout": "vertical",
                  "align": "center",
                  "gap": 16,
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "step-2-circle", "type": "rect", "label": "2", "width": 48, "height": 48, "cornerRadius": 24, "fill": { "type": "solid", "color": "var(brand-accent)" }, "text": "2", "fontSize": 18, "fontWeight": 700, "textColor": "#FFFFFF" },
                    { "id": "step-2-label", "type": "text", "content": "Candidates Test", "fontSize": 16, "fontFamily": "var(font-sans)", "fontWeight": 600, "color": "#111827", "textAlign": "center" },
                    { "id": "step-2-desc", "type": "text", "content": "Proctored, AI-monitored assessment with 6 question formats and a live timer", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#6B7280", "textAlign": "center" }
                  ]
                },
                {
                  "id": "step-3",
                  "type": "frame",
                  "label": "Step 3",
                  "flex": 1,
                  "layout": "vertical",
                  "align": "center",
                  "gap": 16,
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "step-3-circle", "type": "rect", "label": "3", "width": 48, "height": 48, "cornerRadius": 24, "fill": { "type": "solid", "color": "var(brand-accent)" }, "text": "3", "fontSize": 18, "fontWeight": 700, "textColor": "#FFFFFF" },
                    { "id": "step-3-label", "type": "text", "content": "Review CrismaScores", "fontSize": 16, "fontFamily": "var(font-sans)", "fontWeight": 600, "color": "#111827", "textAlign": "center" },
                    { "id": "step-3-desc", "type": "text", "content": "Compare candidates side-by-side by score, sub-scores, and fraud flags", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#6B7280", "textAlign": "center" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "home-features",
          "type": "frame",
          "label": "For-companies feature grid",
          "width": 1440,
          "height": 480,
          "layout": "vertical",
          "align": "center",
          "padding": { "x": 120, "y": 64 },
          "gap": 48,
          "fill": { "type": "solid", "color": "var(brand-light)" },
          "children": [
            { "id": "features-headline", "type": "text", "content": "Everything you need to hire with confidence", "fontSize": 32, "fontFamily": "var(font-sans)", "fontWeight": 700, "color": "#111827", "textAlign": "center" },
            {
              "id": "features-grid",
