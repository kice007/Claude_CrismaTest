                  "height": 220,
                  "cornerRadius": 12,
                  "padding": { "x": 24, "y": 24 },
                  "layout": "vertical",
                  "gap": 16,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "shadow": { "type": "sm" },
                  "children": [
                    { "id": "fc1-icon", "type": "rect", "width": 40, "height": 40, "cornerRadius": 8, "fill": { "type": "solid", "color": "var(brand-light)" }, "label": "[Shield icon]" },
                    { "id": "fc1-title", "type": "text", "content": "Anti-Fraud Monitoring", "fontSize": 16, "fontFamily": "var(font-sans)", "fontWeight": 600, "color": "#111827" },
                    { "id": "fc1-body", "type": "text", "content": "AI-powered webcam proctoring and behavioral analysis flags suspicious patterns in real time", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#6B7280", "lineHeight": 1.5 }
                  ]
                },
                {
                  "id": "feature-card-2",
                  "type": "frame",
                  "label": "Feature card: Speed",
                  "flex": 1,
                  "height": 220,
                  "cornerRadius": 12,
                  "padding": { "x": 24, "y": 24 },
                  "layout": "vertical",
                  "gap": 16,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "shadow": { "type": "sm" },
                  "children": [
                    { "id": "fc2-icon", "type": "rect", "width": 40, "height": 40, "cornerRadius": 8, "fill": { "type": "solid", "color": "var(brand-light)" }, "label": "[Lightning icon]" },
                    { "id": "fc2-title", "type": "text", "content": "Hire 3× Faster", "fontSize": 16, "fontFamily": "var(font-sans)", "fontWeight": 600, "color": "#111827" },
                    { "id": "fc2-body", "type": "text", "content": "Automated scoring and ranking eliminates manual resume screening — results in minutes, not days", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#6B7280", "lineHeight": 1.5 }
                  ]
