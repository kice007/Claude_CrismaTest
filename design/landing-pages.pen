                    { "id": "mobile-signup", "type": "rect", "label": "Sign Up", "flex": 1, "height": 48, "cornerRadius": 8, "fill": { "type": "solid", "color": "var(brand-primary)" }, "text": "Sign Up", "textColor": "#FFFFFF", "fontSize": 15, "fontWeight": 700 }
