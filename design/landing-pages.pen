                    {
                      "type": "text",
                      "id": "EI23H",
                      "fill": "#0F172A",
                      "content": "How long does it take?",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "R7fAP",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Most candidates complete the full test in 10 to 15 minutes. The adaptive format means the test adjusts to your responses — no two sessions are identical.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
