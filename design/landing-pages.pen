          ]
        },
        {
          "id": "home-antifraud",
          "type": "frame",
          "label": "Anti-fraud section",
          "width": 1440,
          "height": 320,
          "layout": "horizontal",
          "align": "center",
          "justify": "center",
          "padding": { "x": 120, "y": 64 },
          "gap": 48,
          "fill": { "type": "solid", "color": "var(brand-navy)" },
          "children": [
            {
              "id": "antifraud-text",
              "type": "frame",
              "flex": 1,
              "layout": "vertical",
              "gap": 16,
              "fill": { "type": "none" },
              "children": [
                { "id": "antifraud-headline", "type": "text", "content": "Built for integrity. Not just speed.", "fontSize": 32, "fontFamily": "var(font-sans)", "fontWeight": 700, "color": "#FFFFFF" },
                { "id": "antifraud-body", "type": "text", "content": "Multi-layer proctoring: gaze tracking, tab-switch detection, ID verification, and AI behavioral analysis. Every test session is auditable.", "fontSize": 16, "color": "#C7D2FE", "lineHeight": 1.6 }
              ]
            },
            {
              "id": "antifraud-badges",
              "type": "frame",
              "flex": 1,
              "layout": "horizontal",
              "gap": 24,
              "justify": "center",
              "fill": { "type": "none" },
              "children": [
