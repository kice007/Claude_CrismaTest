                  "gap": 10,
                  "padding": [
                    24,
                    0
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "5a9Cj",
                      "fill": "#0F172A",
                      "content": "How accurate is the test?",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "jtAsJ",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "CrismaTest combines six evaluation dimensions — logic, communication, job skills, behavioral indicators, anti-fraud consistency, and optional video — to produce a holistic score with significantly higher predictive validity than traditional CV screening.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "zNa0u",
                  "name": "q2",
                  "width": "fill_container",
                  "stroke": {
                    "align": "inside",
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#E2E8F0"
                  },
                  "layout": "vertical",
                  "gap": 10,
                  "padding": [
                    24,
                    0
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "EI23H",
                      "fill": "#0F172A",
                      "content": "How long does it take?",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "R7fAP",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Most candidates complete the full test in 10 to 15 minutes. The adaptive format means the test adjusts to your responses — no two sessions are identical.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "WwJB4",
                  "name": "q3",
                  "width": "fill_container",
                  "stroke": {
                    "align": "inside",
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#E2E8F0"
                  },
                  "layout": "vertical",
                  "gap": 10,
                  "padding": [
                    24,
                    0
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "sf79F",
                      "fill": "#0F172A",
                      "content": "How is cheating prevented?",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "at7N5",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "CrismaTest uses real-time AI proctoring that monitors webcam activity, tab switching, typing patterns, copy/paste behavior, audio environment, and secondary screen usage. Any anomalies are flagged in the candidate's TrustScore breakdown.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "6bimD",
                  "name": "q4",
                  "width": "fill_container",
                  "stroke": {
                    "align": "inside",
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#E2E8F0"
                  },
                  "layout": "vertical",
                  "gap": 10,
                  "padding": [
                    24,
                    0
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "uwI0W",
                      "fill": "#0F172A",
                      "content": "Can companies customize the test?",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "KlD19",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Yes. Companies on Starter, Pro, and Enterprise plans can use the Test Builder to select specific modules, adjust question focus, and add up to 3 custom questions — all without any technical configuration.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "0hiGh",
                  "name": "q5",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 10,
                  "padding": [
                    24,
                    0
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "UhA4L",
                      "fill": "#0F172A",
                      "content": "Can I reuse my CrismaScore?",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "1kqa4",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Absolutely. Your CrismaScore is valid for 12 months. You can share it via a unique profile link, embed it on LinkedIn, or send it directly to any employer — anywhere in the world. Free plan candidates receive 2 free retests.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
