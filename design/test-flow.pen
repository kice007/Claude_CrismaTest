                        { "id": "cs-sq2-c", "type": "rect", "label": "C Accept and reprioritize", "width": 200, "height": 40, "cornerRadius": 8, "fill": { "type": "solid", "color": "#FFFFFF" }, "stroke": { "color": "#E5E7EB", "width": 1.5 }, "text": "C  Accept and reprioritize", "fontSize": 13, "fontFamily": "var(font-sans)", "color": "#374151", "align": "center" }
                      ]
