{
  "version": "1.0",
  "variables": {
    "brand-primary": "#1B4FD8",
    "brand-secondary": "#3B6FE8",
    "brand-navy": "#0F2A6B",
    "brand-light": "#EEF2FF",
    "brand-accent": "#6366F1",
    "font-sans": "Inter",
    "font-mono": "JetBrains Mono"
  },
  "nodes": [
    {
      "id": "intro",
      "type": "frame",
      "label": "intro — /test/[id]/intro desktop",
      "width": 1440,
      "height": 900,
      "fill": { "type": "solid", "color": "var(brand-light)" },
      "layout": "vertical",
      "align": "center",
      "justify": "center",
      "children": [
        {
          "id": "intro-note-nav",
          "type": "note",
          "content": "← NavShell absent on test pages — full-screen focus mode"
        },
        {
          "id": "intro-card",
          "type": "frame",
          "label": "Intro card",
          "width": 600,
          "layout": "vertical",
          "gap": 24,
          "padding": { "x": 48, "y": 48 },
          "fill": { "type": "solid", "color": "#FFFFFF" },
          "cornerRadius": 16,
          "shadow": { "type": "lg" },
          "children": [
            {
              "id": "intro-role-badge",
              "type": "rect",
              "label": "Product Manager Assessment",
              "width": 280,
              "height": 36,
              "cornerRadius": 20,
              "fill": { "type": "solid", "color": "var(brand-accent)" },
              "text": "Product Manager Assessment",
              "fontSize": 13,
              "fontFamily": "var(font-sans)",
              "fontWeight": "semibold",
              "color": "#FFFFFF",
              "align": "center"
            },
            {
              "id": "intro-time-row",
              "type": "frame",
              "label": "Estimated time row",
              "layout": "horizontal",
              "gap": 8,
              "align": "center",
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "intro-clock-icon",
                  "type": "rect",
                  "label": "clock icon",
                  "width": 20,
                  "height": 20,
                  "cornerRadius": 10,
                  "fill": { "type": "solid", "color": "var(brand-primary)", "opacity": 0.15 }
                },
                {
                  "id": "intro-time-text",
                  "type": "text",
                  "label": "10–15 minutes",
                  "fontSize": 15,
                  "fontFamily": "var(font-sans)",
                  "color": "#374151"
                }
              ]
            },
            {
              "id": "intro-modules",
              "type": "frame",
              "label": "Module breakdown",
              "layout": "vertical",
              "gap": 12,
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "intro-module-1",
                  "type": "frame",
                  "label": "Module row: Logic & Reasoning",
                  "layout": "horizontal",
                  "gap": 10,
                  "align": "center",
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "intro-mod1-icon", "type": "rect", "label": "icon", "width": 18, "height": 18, "cornerRadius": 4, "fill": { "type": "solid", "color": "var(brand-primary)", "opacity": 0.2 } },
                    { "id": "intro-mod1-label", "type": "text", "label": "Logic & Reasoning — 4 min", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#4B5563", "flex": 1 },
                    { "id": "intro-mod1-time", "type": "text", "label": "4 min", "fontSize": 13, "fontFamily": "var(font-sans)", "color": "#9CA3AF" }
                  ]
                },
                {
                  "id": "intro-module-2",
                  "type": "frame",
                  "label": "Module row: Communication",
                  "layout": "horizontal",
                  "gap": 10,
                  "align": "center",
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "intro-mod2-icon", "type": "rect", "label": "icon", "width": 18, "height": 18, "cornerRadius": 4, "fill": { "type": "solid", "color": "var(brand-accent)", "opacity": 0.2 } },
                    { "id": "intro-mod2-label", "type": "text", "label": "Communication — 3 min", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#4B5563", "flex": 1 },
                    { "id": "intro-mod2-time", "type": "text", "label": "3 min", "fontSize": 13, "fontFamily": "var(font-sans)", "color": "#9CA3AF" }
                  ]
                },
                {
                  "id": "intro-module-3",
                  "type": "frame",
                  "label": "Module row: Job Skills",
                  "layout": "horizontal",
                  "gap": 10,
                  "align": "center",
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "intro-mod3-icon", "type": "rect", "label": "icon", "width": 18, "height": 18, "cornerRadius": 4, "fill": { "type": "solid", "color": "var(brand-secondary)", "opacity": 0.2 } },
                    { "id": "intro-mod3-label", "type": "text", "label": "Job Skills — 5 min", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#4B5563", "flex": 1 },
                    { "id": "intro-mod3-time", "type": "text", "label": "5 min", "fontSize": 13, "fontFamily": "var(font-sans)", "color": "#9CA3AF" }
                  ]
                },
                {
                  "id": "intro-module-4",
                  "type": "frame",
                  "label": "Module row: Situational Judgment",
                  "layout": "horizontal",
                  "gap": 10,
                  "align": "center",
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "intro-mod4-icon", "type": "rect", "label": "icon", "width": 18, "height": 18, "cornerRadius": 4, "fill": { "type": "solid", "color": "#10B981", "opacity": 0.2 } },
                    { "id": "intro-mod4-label", "type": "text", "label": "Situational Judgment — 3 min", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#4B5563", "flex": 1 },
                    { "id": "intro-mod4-time", "type": "text", "label": "3 min", "fontSize": 13, "fontFamily": "var(font-sans)", "color": "#9CA3AF" }
                  ]
                }
              ]
            },
            {
              "id": "intro-antifraud",
              "type": "frame",
              "label": "Anti-fraud notice",
              "layout": "horizontal",
              "gap": 8,
              "align": "center",
              "padding": { "x": 12, "y": 10 },
              "fill": { "type": "solid", "color": "#FEF3C7" },
              "cornerRadius": 8,
              "children": [
                {
                  "id": "intro-shield-icon",
                  "type": "rect",
                  "label": "shield icon",
                  "width": 16,
                  "height": 16,
                  "cornerRadius": 2,
                  "fill": { "type": "solid", "color": "#D97706" }
                },
                {
                  "id": "intro-antifraud-text",
                  "type": "text",
                  "label": "This test uses webcam monitoring",
                  "fontSize": 13,
                  "fontFamily": "var(font-sans)",
                  "color": "#92400E"
                }
              ]
            },
            {
              "id": "intro-cta",
              "type": "rect",
              "label": "Start Test",
              "width": 504,
              "height": 48,
              "cornerRadius": 8,
              "fill": { "type": "solid", "color": "var(brand-primary)" },
              "text": "Start Test",
              "fontSize": 16,
              "fontFamily": "var(font-sans)",
              "fontWeight": "semibold",
              "color": "#FFFFFF",
              "align": "center"
            }
          ]
        }
      ]
    },
    {
      "id": "check",
      "type": "frame",
      "label": "check — /test/[id]/check desktop",
      "width": 1440,
      "height": 900,
      "fill": { "type": "solid", "color": "var(brand-light)" },
      "layout": "vertical",
      "align": "center",
      "justify": "center",
      "children": [
        {
          "id": "check-note-preflight",
          "type": "note",
          "content": "Pre-flight check: real webcam/mic permission request via browser API — TEST-02"
        },
        {
          "id": "check-inner",
          "type": "frame",
          "label": "Check layout 2-col",
          "width": 960,
          "layout": "horizontal",
          "gap": 40,
          "padding": { "x": 48, "y": 48 },
          "fill": { "type": "solid", "color": "#FFFFFF" },
          "cornerRadius": 16,
          "shadow": { "type": "lg" },
          "children": [
            {
              "id": "check-left",
              "type": "frame",
              "label": "Camera / mic checks",
              "layout": "vertical",
              "gap": 20,
              "fill": { "type": "none" },
              "flex": 1,
              "children": [
                {
                  "id": "check-webcam-placeholder",
                  "type": "rect",
                  "label": "[Webcam preview — browser getUserMedia()]",
                  "width": 380,
                  "height": 240,
                  "cornerRadius": 10,
                  "fill": { "type": "solid", "color": "#111827" },
                  "text": "[Webcam preview — browser getUserMedia()]",
                  "fontSize": 13,
                  "fontFamily": "var(font-sans)",
                  "color": "#9CA3AF",
                  "align": "center"
                },
                {
                  "id": "check-mic-bars",
                  "type": "frame",
                  "label": "Mic level indicator",
                  "layout": "horizontal",
                  "gap": 6,
                  "align": "flex-end",
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "mic-bar-1", "type": "rect", "label": "[Mic level bars — Web Audio API, animated]", "width": 16, "height": 24, "cornerRadius": 3, "fill": { "type": "solid", "color": "var(brand-primary)" } },
                    { "id": "mic-bar-2", "type": "rect", "label": "", "width": 16, "height": 36, "cornerRadius": 3, "fill": { "type": "solid", "color": "var(brand-primary)" } },
                    { "id": "mic-bar-3", "type": "rect", "label": "", "width": 16, "height": 48, "cornerRadius": 3, "fill": { "type": "solid", "color": "var(brand-primary)" } },
                    { "id": "mic-bar-4", "type": "rect", "label": "", "width": 16, "height": 32, "cornerRadius": 3, "fill": { "type": "solid", "color": "var(brand-primary)" } },
                    { "id": "mic-bar-5", "type": "rect", "label": "", "width": 16, "height": 20, "cornerRadius": 3, "fill": { "type": "solid", "color": "var(brand-primary)", "opacity": 0.4 } },
                    { "id": "mic-bar-label", "type": "text", "label": "[Mic level bars — Web Audio API, animated]", "fontSize": 12, "fontFamily": "var(font-sans)", "color": "#6B7280" }
                  ]
                },
                {
                  "id": "check-camera-denied",
                  "type": "note",
                  "content": "[Camera/mic denied — show retry button] — red error banner appears here if permissions denied"
                }
              ]
            },
            {
              "id": "check-right",
              "type": "frame",
              "label": "Checklist and CTA",
              "layout": "vertical",
              "gap": 20,
              "fill": { "type": "none" },
              "flex": 1,
              "children": [
                {
                  "id": "check-heading",
                  "type": "text",
                  "label": "Pre-flight Check",
                  "fontSize": 22,
                  "fontFamily": "var(font-sans)",
                  "fontWeight": "bold",
                  "color": "#111827"
                },
                {
                  "id": "check-checklist",
                  "type": "frame",
                  "label": "Anti-fraud checklist",
                  "layout": "vertical",
                  "gap": 14,
                  "fill": { "type": "none" },
                  "children": [
                    {
                      "id": "check-item-1",
                      "type": "frame",
                      "label": "Camera check",
                      "layout": "horizontal",
                      "gap": 10,
                      "align": "center",
                      "fill": { "type": "none" },
                      "children": [
                        { "id": "chk1-box", "type": "rect", "label": "checkbox checked", "width": 20, "height": 20, "cornerRadius": 4, "fill": { "type": "solid", "color": "var(brand-primary)" } },
                        { "id": "chk1-text", "type": "text", "label": "Camera is working", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" }
                      ]
                    },
                    {
                      "id": "check-item-2",
                      "type": "frame",
                      "label": "Mic check",
                      "layout": "horizontal",
                      "gap": 10,
                      "align": "center",
                      "fill": { "type": "none" },
                      "children": [
                        { "id": "chk2-box", "type": "rect", "label": "checkbox checked", "width": 20, "height": 20, "cornerRadius": 4, "fill": { "type": "solid", "color": "var(brand-primary)" } },
                        { "id": "chk2-text", "type": "text", "label": "Microphone is working", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" }
                      ]
                    },
                    {
                      "id": "check-item-3",
                      "type": "frame",
                      "label": "Alone check",
                      "layout": "horizontal",
                      "gap": 10,
                      "align": "center",
                      "fill": { "type": "none" },
                      "children": [
                        { "id": "chk3-box", "type": "rect", "label": "checkbox unchecked", "width": 20, "height": 20, "cornerRadius": 4, "fill": { "type": "none" }, "stroke": { "color": "#D1D5DB", "width": 2 } },
                        { "id": "chk3-text", "type": "text", "label": "I am alone in the room", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" }
                      ]
                    },
                    {
                      "id": "check-item-4",
                      "type": "frame",
                      "label": "No extra screens",
                      "layout": "horizontal",
                      "gap": 10,
                      "align": "center",
                      "fill": { "type": "none" },
                      "children": [
                        { "id": "chk4-box", "type": "rect", "label": "checkbox unchecked", "width": 20, "height": 20, "cornerRadius": 4, "fill": { "type": "none" }, "stroke": { "color": "#D1D5DB", "width": 2 } },
                        { "id": "chk4-text", "type": "text", "label": "No extra screens or notes visible", "fontSize": 14, "fontFamily": "var(font-sans)", "color": "#374151" }
                      ]
                    }
                  ]
                },
                {
                  "id": "check-disclaimer",
                  "type": "frame",
                  "label": "Disclaimer checkbox",
                  "layout": "horizontal",
                  "gap": 10,
                  "align": "flex-start",
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "disclaimer-box", "type": "rect", "label": "checkbox unchecked", "width": 20, "height": 20, "cornerRadius": 4, "fill": { "type": "none" }, "stroke": { "color": "#D1D5DB", "width": 2 } },
                    { "id": "disclaimer-text", "type": "text", "label": "I agree to the testing conditions and consent to webcam monitoring", "fontSize": 13, "fontFamily": "var(font-sans)", "color": "#6B7280" }
                  ]
                },
                {
                  "id": "check-cta",
                  "type": "rect",
                  "label": "I'm Ready (disabled — opacity 50%)",
                  "width": 300,
                  "height": 48,
                  "cornerRadius": 8,
                  "fill": { "type": "solid", "color": "var(brand-primary)", "opacity": 0.5 },
                  "text": "I'm Ready",
                  "fontSize": 16,
                  "fontFamily": "var(font-sans)",
                  "fontWeight": "semibold",
                  "color": "#FFFFFF",
                  "align": "center"
                },
                {
                  "id": "check-cta-note",
                  "type": "note",
                  "content": "Activates only when all checkboxes checked — disabled state shown (opacity 50%)"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "questions--qcm",
      "type": "frame",
      "label": "questions--qcm — QCM single-select (1440px)",
      "width": 1440,
      "height": 900,
      "fill": { "type": "solid", "color": "var(brand-light)" },
      "layout": "vertical",
      "gap": 0,
      "children": [
        {
          "id": "qcm-header",
          "type": "frame",
          "label": "Questions header",
          "width": 1440,
          "height": 64,
          "layout": "horizontal",
          "align": "center",
          "gap": 16,
          "padding": { "x": 40, "y": 0 },
          "fill": { "type": "solid", "color": "#FFFFFF" },
          "shadow": { "type": "sm" },
          "children": [
            {
              "id": "qcm-progress-bar",
              "type": "frame",
              "label": "Progress bar",
              "layout": "vertical",
              "fill": { "type": "none" },
              "flex": 1,
              "children": [
                {
                  "id": "qcm-progress-track",
                  "type": "rect",
                  "label": "Progress track",
                  "width": 600,
                  "height": 6,
                  "cornerRadius": 3,
                  "fill": { "type": "solid", "color": "#E5E7EB" }
                },
                {
                  "id": "qcm-progress-fill",
                  "type": "rect",
                  "label": "Progress fill 40%",
                  "width": 240,
                  "height": 6,
                  "cornerRadius": 3,
                  "fill": { "type": "solid", "color": "var(brand-primary)" }
                },
                {
                  "id": "qcm-progress-label",
                  "type": "text",
                  "label": "Question 4 of 10",
                  "fontSize": 12,
                  "fontFamily": "var(font-sans)",
                  "color": "#6B7280"
                }
              ]
            },
            {
              "id": "qcm-module-badge",
              "type": "rect",
              "label": "Logic & Reasoning",
              "width": 140,
              "height": 28,
              "cornerRadius": 14,
              "fill": { "type": "solid", "color": "var(brand-accent)" },
              "text": "Logic & Reasoning",
              "fontSize": 12,
              "fontFamily": "var(font-sans)",
              "fontWeight": "semibold",
              "color": "#FFFFFF",
              "align": "center"
            },
            {
              "id": "qcm-timer",
              "type": "text",
              "label": "12:34",
              "fontSize": 18,
              "fontFamily": "var(font-mono)",
              "fontWeight": "bold",
              "color": "#374151"
            }
          ]
        },
        {
          "id": "qcm-timer-note",
          "type": "note",
          "content": "Timer: JetBrains Mono — color #F59E0B (amber) at 1:00 remaining, #EF4444 (red) at 0:30 remaining"
        },
        {
          "id": "qcm-body",
          "type": "frame",
          "label": "QCM body",
          "layout": "vertical",
          "gap": 20,
          "padding": { "x": 240, "y": 40 },
          "fill": { "type": "none" },
          "flex": 1,
          "children": [
            {
              "id": "qcm-question-text",
              "type": "text",
              "label": "A project is delayed by 2 weeks. What is the most effective first step as a Product Manager?",
              "fontSize": 20,
              "fontFamily": "var(font-sans)",
              "fontWeight": "semibold",
              "color": "#111827"
            },
            {
              "id": "qcm-options",
              "type": "frame",
              "label": "Answer options",
              "layout": "vertical",
              "gap": 12,
              "fill": { "type": "none" },
              "children": [
                {
                  "id": "qcm-opt-a",
                  "type": "rect",
                  "label": "A — Immediately escalate to leadership",
                  "width": 800,
                  "height": 56,
                  "cornerRadius": 10,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "stroke": { "color": "#E5E7EB", "width": 1.5 },
                  "text": "A  Immediately escalate to leadership",
                  "fontSize": 15,
                  "fontFamily": "var(font-sans)",
                  "color": "#374151",
                  "padding": { "x": 20, "y": 0 }
                },
                {
                  "id": "qcm-opt-b",
                  "type": "rect",
                  "label": "B — Conduct a root-cause analysis with the team (selected)",
                  "width": 800,
                  "height": 56,
                  "cornerRadius": 10,
                  "fill": { "type": "solid", "color": "var(brand-light)" },
                  "stroke": { "color": "var(brand-primary)", "width": 2 },
                  "text": "B  Conduct a root-cause analysis with the team",
                  "fontSize": 15,
                  "fontFamily": "var(font-sans)",
                  "fontWeight": "semibold",
                  "color": "var(brand-primary)",
                  "padding": { "x": 20, "y": 0 }
                },
                {
                  "id": "qcm-opt-c",
                  "type": "rect",
                  "label": "C — Revise the project timeline unilaterally",
                  "width": 800,
                  "height": 56,
                  "cornerRadius": 10,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "stroke": { "color": "#E5E7EB", "width": 1.5 },
                  "text": "C  Revise the project timeline unilaterally",
                  "fontSize": 15,
                  "fontFamily": "var(font-sans)",
                  "color": "#374151",
                  "padding": { "x": 20, "y": 0 }
                },
                {
                  "id": "qcm-opt-d",
                  "type": "rect",
                  "label": "D — Reduce the feature scope without informing stakeholders",
                  "width": 800,
                  "height": 56,
                  "cornerRadius": 10,
                  "fill": { "type": "solid", "color": "#FFFFFF" },
                  "stroke": { "color": "#E5E7EB", "width": 1.5 },
                  "text": "D  Reduce the feature scope without informing stakeholders",
                  "fontSize": 15,
                  "fontFamily": "var(font-sans)",
                  "color": "#374151",
                  "padding": { "x": 20, "y": 0 }
                }
              ]
            },
            {
              "id": "qcm-multiselect-note",
              "type": "note",
              "content": "Multi-select variant: checkboxes instead of radio; per TEST-03"
            }
          ]
        },
        {
          "id": "qcm-footer",
          "type": "frame",
          "label": "Questions footer nav",
          "width": 1440,
          "height": 72,
          "layout": "horizontal",
          "align": "center",
          "justify": "space-between",
          "padding": { "x": 40, "y": 0 },
          "fill": { "type": "solid", "color": "#FFFFFF" },
          "shadow": { "type": "sm" },
          "children": [
            {
              "id": "qcm-prev-btn",
              "type": "rect",
              "label": "← Previous",
              "width": 120,
              "height": 40,
              "cornerRadius": 8,
              "fill": { "type": "none" },
              "stroke": { "color": "var(brand-primary)", "width": 1.5 },
              "text": "← Previous",
              "fontSize": 14,
              "fontFamily": "var(font-sans)",
              "color": "var(brand-primary)",
              "align": "center"
            },
            {
              "id": "qcm-flag-btn",
              "type": "text",
              "label": "Flag for Review",
              "fontSize": 14,
              "fontFamily": "var(font-sans)",
              "color": "var(brand-accent)"
            },
            {
              "id": "qcm-next-btn",
              "type": "rect",
              "label": "Next →",
              "width": 120,
              "height": 40,
              "cornerRadius": 8,
              "fill": { "type": "solid", "color": "var(brand-primary)" },
              "text": "Next →",
              "fontSize": 14,
              "fontFamily": "var(font-sans)",
              "fontWeight": "semibold",
              "color": "#FFFFFF",
              "align": "center"
            }
          ]
        }
      ]
    },
    {
      "id": "questions--dragdrop",
      "type": "frame",
      "label": "questions--dragdrop — drag & drop ranking (1440px)",
      "width": 1440,
      "height": 900,
      "fill": { "type": "solid", "color": "var(brand-light)" },
      "layout": "vertical",
      "gap": 0,
      "children": [
        {
          "id": "dd-header",
          "type": "frame",
          "label": "Questions header",
          "width": 1440,
          "height": 64,
          "layout": "horizontal",
          "align": "center",
          "gap": 16,
          "padding": { "x": 40, "y": 0 },
          "fill": { "type": "solid", "color": "#FFFFFF" },
          "shadow": { "type": "sm" },
          "children": [
            {
              "id": "dd-progress-bar",
              "type": "frame",
              "label": "Progress bar",
              "layout": "horizontal",
              "gap": 8,
              "fill": { "type": "none" },
