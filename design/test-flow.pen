                        { "id": "cs-sq1-c", "type": "rect", "label": "C Hire contractors", "width": 180, "height": 40, "cornerRadius": 8, "fill": { "type": "solid", "color": "#FFFFFF" }, "stroke": { "color": "#E5E7EB", "width": 1.5 }, "text": "C  Hire contractors", "fontSize": 13, "fontFamily": "var(font-sans)", "color": "#374151", "align": "center" }
