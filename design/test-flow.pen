                { "id": "sim-customer-name", "type": "text", "label": "Sophie Martin — Enterprise Account", "fontSize": 14, "fontFamily": "var(font-sans)", "fontWeight": "semibold", "color": "#111827" },
                { "id": "sim-message", "type": "frame", "label": "Customer message bubble", "layout": "vertical", "padding": { "x": 16, "y": 12 }, "fill": { "type": "solid", "color": "#F3F4F6" }, "cornerRadius": 10, "children": [
