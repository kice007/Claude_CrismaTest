                  "align": "center",
                  "fill": { "type": "none" },
                  "children": [
                    { "id": "calc-dot-3", "type": "rect", "label": "spinner dot", "width": 20, "height": 20, "cornerRadius": 10, "fill": { "type": "solid", "color": "var(brand-secondary)", "opacity": 0.7 } },
                    { "id": "calc-step-3-text", "type": "text", "label": "Computing sub-scores.", "fontSize": 16, "fontFamily": "var(font-sans)", "color": "#D1D5DB" }
                  ]
