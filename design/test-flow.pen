                        { "id": "cs-sq1-a", "type": "rect", "label": "A Delay expansion", "width": 180, "height": 40, "cornerRadius": 8, "fill": { "type": "solid", "color": "#FFFFFF" }, "stroke": { "color": "#E5E7EB", "width": 1.5 }, "text": "A  Delay expansion", "fontSize": 13, "fontFamily": "var(font-sans)", "color": "#374151", "align": "center" },
